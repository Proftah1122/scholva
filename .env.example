# Database
DATABASE_URL="postgresql://user:pass@localhost:5432/scholva?schema=public"
DIRECT_URL="postgresql://user:pass@localhost:5432/scholva?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth - RS256 key pair
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ACCESS_TOKEN_EXPIRY="15m"
JWT_REFRESH_TOKEN_EXPIRY="30d"

# AI
VOYAGE_API_KEY="pa-xxx"
ANTHROPIC_API_KEY="sk-ant-xxx"

# Storage
CLOUDINARY_URL="cloudinary://xxx:xxx@xxx"
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
CLOUDINARY_UPLOAD_PRESET="scholva_projects"

# Email
RESEND_API_KEY="re_xxx"
RESEND_FROM_EMAIL="noreply@scholva.ng"

# Payments
PAYSTACK_SECRET_KEY="sk_live_xxx"
PAYSTACK_WEBHOOK_SECRET="xxx"
PAYSTACK_PUBLIC_KEY="pk_live_xxx"

# App
NODE_ENV="development"
PORT="3001"
FRONTEND_URL="http://localhost:3000"
API_URL="http://localhost:3001"

# Worker
WORKER_CONCURRENCY="3"
PDF_MAX_SIZE_MB="25"
SUGGESTION_BATCH_SIZE="5"
SUGGESTION_NOVELTY_THRESHOLD="0.88"
PROBLEM_SURFACING_EMAIL_DAILY_LIMIT="1"
