  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@scholva/shared-types": "0.1.0",
    "@scholva/shared-utils": "0.1.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "supertest": "^7.2.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/supertest": "^7.2.0",
    "prisma": "^5.22.0",
    "tsx": "^4.16.2",
    "vitest": "^4.1.9"
